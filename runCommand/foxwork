#!/bin/bash

# --- CONFIGURATION ---
BIN_PATH="/tmp/daspaces/software/firefox/firefox"
PROFILE_BASE="/tmp/daspaces/udff"

# 1. Check if an argument was provided (e.g., ./script.sh 1)
if [ -z "$1" ]; then
    echo "Error: No profile folder specified. Usage: $0 <profile_name>"
    exit 1
fi

# 2. Define Paths (No '+' needed in Bash for joining strings)
PROFILE_PATH="$PROFILE_BASE/$1"

# 3. Check if the source profile actually exists on the USB
if [ ! -d "$PROFILE_PATH" ]; then
    echo "Error: Profile path $PROFILE_PATH does not exist!"
    exit 1
fi

# We use $BIN_PATH here to ensure it uses your ESR 115 version
"$BIN_PATH" --profile "$PROFILE_PATH" --no-remote

rm -fr "$PROFILE_PATH/cache2"
rm -fr "$PROFILE_PATH/datareporting"
rm -fr "$PROFILE_PATH/saved-telemetry-pings"
rm -fr "$PROFILE_PATH/startupCache"
rm -fr "$PROFILE_PATH/thumbnails"

echo "Sync Complete! Safe to unplug USB or power off."
